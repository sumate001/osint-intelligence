# ───── Database ─────
POSTGRES_DB=osintdesk
POSTGRES_USER=osint
POSTGRES_PASSWORD=changeme
POSTGRES_URL=postgresql+asyncpg://osint:changeme@postgres:5432/osintdesk

# ───── Redis ─────
REDIS_URL=redis://redis:6379/0

# ───── Neo4j ─────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123
NEO4J_URI=bolt://neo4j:7687

# ───── Meilisearch ─────
MEILI_MASTER_KEY=changeme_master_key
MEILISEARCH_URL=http://meilisearch:7700

# ───── MinIO ─────
MINIO_USER=osint
MINIO_PASSWORD=changeme123
MINIO_ENDPOINT=minio:9000

# ───── SearXNG ─────
SEARXNG_URL=http://searxng:8080

# ───── OSINT Tools ─────
SPIDERFOOT_URL=http://spiderfoot:5001
# MIROFISH_URL ไม่ set → simulation ใช้ LLM fallback (MiroFish ต้องการ Zep graph workflow)

# ───── MiroFish — Zep memory graph (optional) ─────
# รับ API key ฟรีที่ https://app.getzep.com/ (free tier พอใช้)
# ถ้าไม่ set → MiroFish ทำงานได้ แต่ไม่มี persistent agent memory
ZEP_API_KEY=

# ───── Ollama (รันบน host Ubuntu — ไม่ได้อยู่ใน compose) ─────
# ถ้า Ollama อยู่บนเครื่องเดียวกับ Docker:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# ถ้า Ollama อยู่คนละเครื่อง (เช่น A5000 แยก) ใช้ IP จริง:
# OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b

# ───── Model routing per module ─────
TRIAGE_MODEL=qwen3:8b
BRIEF_MODEL=qwen3:14b
VISION_MODEL=gemma3:27b
SIMULATION_MODEL=qwen3:14b

# ───── Auth ─────
SECRET_KEY=change_this_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=10080
